{
  "name": "@open-pets/installer",
  "version": "0.1.1",
  "description": "Shared OpenPets pet installation logic.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@open-pets/client": "0.1.1",
    "@open-pets/core": "0.1.1",
    "@open-pets/pet-format-codex": "0.1.0",
    "jszip": "^3.10.1"
  },
  "scripts": {
    "build": "rm -rf dist && bunx tsc -p tsconfig.json",
    "prepack": "bun run build",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
