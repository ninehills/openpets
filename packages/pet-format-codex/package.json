{
  "name": "@open-pets/pet-format-codex",
  "version": "0.1.0",
  "description": "Codex/Petdex pet format loader for OpenPets.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
